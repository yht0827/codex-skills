#!/usr/bin/env zsh
set -euo pipefail

if ! command -v tmux >/dev/null 2>&1; then
  echo "[tdd-team] tmux를 찾지 못했습니다. 먼저 tmux를 설치하세요." >&2
  exit 1
fi

workdir="${1:-$PWD}"
shift || true
requirement="$*"

if [ ! -d "$workdir" ]; then
  echo "[tdd-team] 디렉터리가 없습니다: $workdir" >&2
  exit 1
fi

cd "$workdir"

dir_name="${PWD:t}"
[ -n "$dir_name" ] || dir_name="home"
safe_name="$(printf '%s' "$dir_name" | tr -c '[:alnum:]_-' '-')"
session="tdd-team-${safe_name}"
prompt_dir="$PWD/.tdd-team/prompts"
mkdir -p "$prompt_dir"

detect_environment_context() {
  local source_dir="확인 필요"
  local test_dir="확인 필요"
  local test_cmd="확인 필요"
  local test_framework="확인 필요"

  if [ -d "src/main/java" ]; then
    source_dir="src/main/java"
  elif [ -d "src/main/kotlin" ]; then
    source_dir="src/main/kotlin"
  elif [ -d "src" ]; then
    source_dir="src"
  fi

  if [ -d "src/test/java" ]; then
    test_dir="src/test/java"
  elif [ -d "src/test/kotlin" ]; then
    test_dir="src/test/kotlin"
  elif [ -d "test" ]; then
    test_dir="test"
  elif [ -d "tests" ]; then
    test_dir="tests"
  fi

  if [ -f "build.gradle.kts" ] || [ -f "build.gradle" ]; then
    if [ -x "./gradlew" ]; then
      test_cmd="./gradlew test"
    else
      test_cmd="gradle test"
    fi
    test_framework="Gradle 테스트 설정 확인"
  elif [ -f "pom.xml" ]; then
    if [ -x "./mvnw" ]; then
      test_cmd="./mvnw test"
    else
      test_cmd="mvn test"
    fi
    test_framework="Maven 테스트 설정 확인"
  elif [ -f "package.json" ]; then
    test_cmd="npm test"
    test_framework="package.json scripts 확인"
  elif [ -f "Cargo.toml" ]; then
    test_cmd="cargo test"
    test_framework="Rust cargo test"
  elif [ -f "go.mod" ]; then
    test_cmd="go test ./..."
    test_framework="Go test"
  elif [ -f "pyproject.toml" ] || [ -f "pytest.ini" ]; then
    test_cmd="pytest"
    test_framework="pytest"
  fi

  cat <<ENV
PROJECT_ROOT: $PWD
SOURCE_DIR: $source_dir
TEST_DIR: $test_dir
TEST_CMD: $test_cmd
TEST_FRAMEWORK: $test_framework
ENV
}

detect_ralph_context() {
  if [ -f "prd.json" ]; then
    cat <<RALPH
Ralph JSON: prd.json 감지됨
- passes:false story 중 priority가 가장 낮은 항목을 현재 TDD task 후보로 사용한다.
- story의 id, title, description, acceptanceCriteria를 읽고 필요하면 더 작은 TDD task로 나눈다.
- Red/Green/Refactor와 검증이 끝난 뒤에만 passes:true 전환과 progress.txt 기록을 판단한다.
RALPH
  else
    echo "Ralph JSON: prd.json 없음"
  fi
}

environment_context="$(detect_environment_context)"
ralph_context="$(detect_ralph_context)"

attach_or_print() {
  local attach_session="$1"
  if [ -t 1 ]; then
    tmux attach -t "$attach_session"
  else
    echo "[tdd-team] tmux agent team 준비 완료: $attach_session"
    echo "[tdd-team] 터미널에서 접속: tmux attach -t $attach_session"
  fi
}

cat > "$prompt_dir/team-lead.txt" <<PROMPT
너는 TDD Team Lead다.

목표:
- 사용자의 개발 요구사항을 받아 작은 task로 분할한다.
- 각 task마다 Red → Green → Refactor phase를 순차 진행시킨다.
- Red/Green/Refactor pane에 필요한 지시를 tmux send-keys로 전달해도 된다.
- 같은 파일을 동시에 수정하게 하지 않는다.
- 각 phase 후 테스트 결과를 확인하고 다음 phase로 넘어간다.
- task 단위로 커밋한다.

팀 pane:
- Red pane: 실패 테스트 작성과 실패 확인만 담당
- Green pane: 실패 테스트 통과를 위한 최소 production code만 담당
- Refactor pane: 테스트 통과 상태를 유지하며 리팩터링만 담당

현재 요구사항:
${requirement:-요구사항이 비어 있으면 사용자에게 구현 요구사항을 먼저 물어봐라.}

환경 컨텍스트:
$environment_context

환경 규칙:
- 실제 파일과 빌드 설정을 먼저 확인해 위 환경 추정이 맞는지 검증한다.
- TEST_CMD가 "확인 필요"이거나 틀렸다면 사용자에게 확인하거나 프로젝트에 맞게 명시적으로 교정한다.
- task 진행 상태를 [x]/[>]/[ ]로 표시한다.

Ralph 연동:
$ralph_context

먼저 요구사항을 요약하고 task 목록을 작성한 뒤, Task 1의 Red phase부터 시작해라.
PROMPT

cat > "$prompt_dir/red.txt" <<PROMPT
너는 TDD Red Agent다.

역할:
- Team Lead가 지정한 task에 대해 실패하는 테스트를 작성한다.
- production code는 구현하지 않는다.
- 테스트를 실행해 실패를 확인한다.
- 실패가 의도한 이유인지 보고한다.

환경 컨텍스트:
$environment_context

규칙:
- 한 번에 하나의 동작만 검증하는 작은 테스트를 작성한다.
- 테스트는 컴파일은 되어야 하지만 의도한 이유로 실패해야 한다.
- 컴파일을 위해 source stub이 꼭 필요하면 실제 구현 없이 예외/기본값만 둔다.
- 새 테스트가 이미 통과하면 ALREADY_PASSES로 보고하고 production code를 건드리지 않는다.
- 실패 파일, 테스트 메서드, 실패 메시지, 생성한 stub을 보고한다.

대기 규칙:
- Team Lead 또는 사용자의 명시적 지시가 오기 전에는 파일을 수정하지 말고 대기한다.
PROMPT

cat > "$prompt_dir/green.txt" <<PROMPT
너는 TDD Green Agent다.

역할:
- Red Agent가 만든 실패 테스트를 통과시키는 최소 production code만 작성한다.
- 추가 기능, 과한 추상화, 리팩터링은 하지 않는다.
- 테스트를 실행해 통과를 확인한다.

환경 컨텍스트:
$environment_context

규칙:
- 테스트 파일을 수정하지 않는다.
- 실패 테스트가 요구하는 가장 작은 production code만 작성한다.
- 하드코딩, 단순 조건문, 중복은 Green phase에서 허용된다.
- TEST_CMD로 전체 테스트를 실행하고 모든 테스트 통과 여부를 보고한다.
- 다른 테스트가 깨지면 원인을 분석하고 더 작은 구현으로 조정한다.

대기 규칙:
- Team Lead 또는 사용자의 명시적 지시가 오기 전에는 파일을 수정하지 말고 대기한다.
PROMPT

cat > "$prompt_dir/refactor.txt" <<PROMPT
너는 TDD Refactor Agent다.

역할:
- Green 후 테스트가 통과한 상태에서만 리팩터링한다.
- 동작 변경 없이 이름, 중복, 책임 분리, 가독성만 정리한다.
- 리팩터링 후 관련 테스트를 다시 실행한다.

환경 컨텍스트:
$environment_context

규칙:
- 새 기능이나 새 테스트를 추가하지 않는다.
- production code와 test code 모두 정리할 수 있지만 동작은 바꾸지 않는다.
- 중복 제거, 이름 개선, 작은 함수/클래스 추출, 조건 단순화에 집중한다.
- 리팩터링할 부분이 없으면 억지로 바꾸지 말고 "리팩터링 불필요"라고 보고한다.
- 변경 후 TEST_CMD 또는 관련 테스트를 실행해 green 상태를 확인한다.

대기 규칙:
- Team Lead 또는 사용자의 명시적 지시가 오기 전에는 파일을 수정하지 말고 대기한다.
PROMPT

start_codex_from_file() {
  local pane="$1"
  local prompt_file="$2"
  local current_command
  current_command="$(tmux display-message -p -t "$pane" '#{pane_current_command}' 2>/dev/null || true)"

  case "$current_command" in
    codex|codex-*)
      return 0
      ;;
  esac

  local cmd="codex --dangerously-bypass-approvals-and-sandbox \"\$(cat ${(q)prompt_file})\""
  tmux send-keys -l -t "$pane" "$cmd"
  tmux send-keys -t "$pane" C-m
}

codex_command_from_file() {
  local prompt_file="$1"
  printf 'codex --dangerously-bypass-approvals-and-sandbox "$(cat %s)"' "${(q)prompt_file}"
}

split_codex_pane() {
  local split_args="$1"
  local target_pane="$2"
  local prompt_file="$3"
  local cmd

  cmd="$(codex_command_from_file "$prompt_file")"
  tmux split-window ${(z)split_args} -P -F '#{pane_id}' -t "$target_pane" -c "$PWD" "$cmd"
}

set_role_titles() {
  local target="$1"
  local lead_pane="$2"
  local red_pane="$3"
  local green_pane="$4"
  local refactor_pane="$5"
  local target_session="${target%%:*}"

  tmux set-option -t "$target_session" allow-set-title off >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" allow-set-title off >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" allow-rename off >/dev/null 2>&1 || true
  tmux set-option -w -u -t "$target" pane-border-style >/dev/null 2>&1 || true
  tmux set-option -w -u -t "$target" pane-active-border-style >/dev/null 2>&1 || true
  tmux set-option -w -t "$target" pane-border-status top >/dev/null
  tmux set-option -w -t "$target" pane-border-format ' #{pane_title} ' >/dev/null

  tmux select-pane -t "$lead_pane" -T '#[fg=colour45,bold]team-lead#[default]'
  tmux select-pane -t "$red_pane" -T '#[fg=colour203,bold]red#[default]'
  tmux select-pane -t "$green_pane" -T '#[fg=colour114,bold]green#[default]'
  tmux select-pane -t "$refactor_pane" -T '#[fg=colour141,bold]refactor#[default]'
}

configure_current_window() {
  local target
  local lead_pane
  local red_pane
  local green_pane
  local refactor_pane
  local pane_count
  local pane_id
  local pane_title

  target="$(tmux display-message -p '#S:#I')"
  lead_pane="$(tmux display-message -p '#{pane_id}')"
  pane_count="$(tmux list-panes -t "$target" -F '#{pane_id}' | wc -l | tr -d ' ')"

  if [ "$pane_count" -ne 1 ]; then
    if [ "$pane_count" -eq 4 ]; then
      lead_pane=""
      red_pane=""
      green_pane=""
      refactor_pane=""

      while IFS=$'\t' read -r pane_id pane_title; do
        case "$pane_title" in
          *team-lead*) lead_pane="$pane_id" ;;
          *red*) red_pane="$pane_id" ;;
          *green*) green_pane="$pane_id" ;;
          *refactor*) refactor_pane="$pane_id" ;;
        esac
      done < <(tmux list-panes -t "$target" -F '#{pane_id}	#{pane_title}')

      if [ -n "${lead_pane:-}" ] && [ -n "${red_pane:-}" ] && [ -n "${green_pane:-}" ] && [ -n "${refactor_pane:-}" ]; then
        set_role_titles "$target" "$lead_pane" "$red_pane" "$green_pane" "$refactor_pane"
        start_codex_from_file "$lead_pane" "$prompt_dir/team-lead.txt"
        start_codex_from_file "$red_pane" "$prompt_dir/red.txt"
        start_codex_from_file "$green_pane" "$prompt_dir/green.txt"
        start_codex_from_file "$refactor_pane" "$prompt_dir/refactor.txt"
        tmux select-pane -t "$lead_pane"
        tmux refresh-client -S >/dev/null 2>&1 || true
        echo "[tdd-team] 기존 TDD team pane 구성을 재사용했습니다: $target"
        return 0
      fi
    fi

    echo "[tdd-team] 현재 window에는 pane이 $pane_count개 있습니다." >&2
    echo "[tdd-team] 현재 window 모드는 pane 1개 상태이거나 이미 team-lead/red/green/refactor로 구성된 4분할 상태여야 합니다." >&2
    echo "[tdd-team] 기존 pane을 정리하거나 tmux 밖에서 실행해 별도 세션 fallback을 사용하세요." >&2
    exit 1
  fi

  # 2x2 role layout: lead/red on top, green/refactor on bottom.
  red_pane="$(split_codex_pane "-h" "$lead_pane" "$prompt_dir/red.txt")"
  green_pane="$(split_codex_pane "-v" "$lead_pane" "$prompt_dir/green.txt")"
  refactor_pane="$(split_codex_pane "-v" "$red_pane" "$prompt_dir/refactor.txt")"

  set_role_titles "$target" "$lead_pane" "$red_pane" "$green_pane" "$refactor_pane"

  start_codex_from_file "$lead_pane" "$prompt_dir/team-lead.txt"

  tmux select-pane -t "$lead_pane"
  tmux refresh-client -S >/dev/null 2>&1 || true
  echo "[tdd-team] 현재 tmux window에 TDD team pane 구성을 완료했습니다: $target"
}

configure_new_session() {
  local target
  local lead_pane
  local red_pane
  local green_pane
  local refactor_pane

  if tmux has-session -t "$session" 2>/dev/null; then
    attach_or_print "$session"
    exit 0
  fi

  tmux new-session -d -s "$session" -c "$PWD" -n team
  target="${session}:team"
  lead_pane="$(tmux display-message -p -t "$target" '#{pane_id}')"
  red_pane="$(split_codex_pane "-h" "$lead_pane" "$prompt_dir/red.txt")"
  green_pane="$(split_codex_pane "-v" "$lead_pane" "$prompt_dir/green.txt")"
  refactor_pane="$(split_codex_pane "-v" "$red_pane" "$prompt_dir/refactor.txt")"

  set_role_titles "$target" "$lead_pane" "$red_pane" "$green_pane" "$refactor_pane"

  start_codex_from_file "$lead_pane" "$prompt_dir/team-lead.txt"

  tmux select-pane -t "$lead_pane"
  attach_or_print "$session"
}

if [ -n "${TMUX:-}" ] && [ -z "${TDD_TEAM_FORCE_NEW_SESSION:-}" ]; then
  configure_current_window
else
  configure_new_session
fi
